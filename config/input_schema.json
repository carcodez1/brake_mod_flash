{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Brake Flasher Pattern Config",
    "type": "object",
    "required": [
      "version",
      "pattern",
      "metadata"
    ],
    "properties": {
      "version": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$"
      },
      "generated": {
        "type": "string",
        "format": "date-time"
      },
      "pattern": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": [
            "count",
            "on",
            "off"
          ],
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 1
            },
            "on": {
              "type": "integer",
              "minimum": 1
            },
            "off": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      },
      "metadata": {
        "type": "object",
        "required": [
          "config_id",
          "legal_notice"
        ],
        "properties": {
          "config_id": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9\\-_]+$"
          },
          "source": {
            "type": "string"
          },
          "legal_notice": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  }
  